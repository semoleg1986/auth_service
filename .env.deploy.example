# auth_service deploy profile
AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/auth_service
AUTH_USE_INMEMORY=0
AUTH_AUTO_CREATE_SCHEMA=0
AUTH_JWT_ISSUER=auth_service
AUTH_JWT_AUDIENCE=platform_clients
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_JWT_REFRESH_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_MAX=20
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
AUTH_JWT_PRIVATE_KEY_PEM=__SET_IN_SECRETS__
AUTH_JWT_PUBLIC_KEY_PEM=__SET_IN_SECRETS__

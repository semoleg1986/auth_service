# auth_service env profiles
#
# Как использовать:
# 1) Скопируйте нужный профиль в .env
# 2) Запустите сервис
#
# Пример:
#   cp .env.local.example .env
#   затем оставьте только один профиль (или нужные переменные)

############################################################
# PROFILE: dev-inmemory
############################################################
# AUTH_USE_INMEMORY=1
# AUTH_DATABASE_URL=sqlite:///./auth_service.db
# AUTH_AUTO_CREATE_SCHEMA=0
# AUTH_JWT_ISSUER=auth_service
# AUTH_JWT_AUDIENCE=platform_clients
# AUTH_JWT_ACCESS_TTL_SECONDS=3600
# AUTH_JWT_REFRESH_TTL_SECONDS=2592000
# AUTH_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n<dev-private-key>\n-----END PRIVATE KEY-----
# AUTH_JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n<dev-public-key>\n-----END PUBLIC KEY-----

############################################################
# PROFILE: dev-postgres
############################################################
# AUTH_USE_INMEMORY=0
# AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/auth_service
# AUTH_AUTO_CREATE_SCHEMA=0
# AUTH_JWT_ISSUER=auth_service
# AUTH_JWT_AUDIENCE=platform_clients
# AUTH_JWT_ACCESS_TTL_SECONDS=3600
# AUTH_JWT_REFRESH_TTL_SECONDS=2592000
# AUTH_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n<dev-private-key>\n-----END PRIVATE KEY-----
# AUTH_JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n<dev-public-key>\n-----END PUBLIC KEY-----

############################################################
# PROFILE: test-postgres
############################################################
# AUTH_USE_INMEMORY=0
# AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/auth_service_test
# AUTH_AUTO_CREATE_SCHEMA=0
# AUTH_JWT_ISSUER=auth_service
# AUTH_JWT_AUDIENCE=platform_clients
# AUTH_JWT_ACCESS_TTL_SECONDS=300
# AUTH_JWT_REFRESH_TTL_SECONDS=3600
# AUTH_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n<test-private-key>\n-----END PRIVATE KEY-----
# AUTH_JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n<test-public-key>\n-----END PUBLIC KEY-----
